---
// 全ページ共通の枠。<head>のメタ・OGP・canonical・構造化データ（JSON-LD）を出力。
import '../styles/global.css';
const {
  title,
  description,
  canonical,
  published,
  updated,
  author = 'オレタチ編集部',
  breadcrumb = [],
  faq = [],
} = Astro.props;

// 記事/Q&A（published を渡すページ）のみ Article 構造化データを出す。
// about（規約・運営者情報など）は published を渡さない＝Article 扱いにせず日付undefinedを避ける。
const articleLd = published
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      datePublished: published,
      dateModified: updated,
      author: { '@type': 'Organization', name: author },
      publisher: { '@type': 'Organization', name: 'オレタチ' },
      mainEntityOfPage: canonical,
    }
  : null;
const crumbLd = breadcrumb && breadcrumb.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumb.map((n, i) => ({ '@type': 'ListItem', position: i + 1, name: n })),
    }
  : null;
const faqLd = faq && faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" /><!-- 準備中：検索登録させない。index解禁OKになったら、この1行を削除して再デプロイ -->
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    {articleLd && <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />}
    {crumbLd && <script type="application/ld+json" set:html={JSON.stringify(crumbLd)} />}
    {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd)} />}
  </head>
  <body>
    <header class="site-header">
      <a href="/" class="brand">オレタチ</a>
      <nav class="site-nav"><a href="/">記事</a><a href="/qa">Q&amp;A</a><a href="/shindan">初動ナビ</a></nav>
    </header>
    <main><slot /></main>
    <footer class="site-footer">
      <nav class="foot-nav"><a href="/about/operator">運営者情報</a><a href="/about/editorial">編集方針</a><a href="/about/privacy">プライバシーポリシー</a><a href="/about/terms">利用規約</a></nav>
      <p>&copy; オレタチ</p>
    </footer>
  </body>
</html>
