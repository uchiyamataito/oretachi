---
// 全ページ共通の枠。<head>のメタ・OGP・canonical・構造化データ（JSON-LD）を出力。
import '../styles/global.css';
import { withTrailingSlash } from '../utils/url';
const {
  title,
  description,
  canonical,
  published,
  updated,
  author = 'オレタチ編集部',
  breadcrumb = [],
  faq = [],
} = Astro.props;

// canonical は配信URL（ディレクトリ形式＝末尾スラッシュ付き）に正規化する。
// 明示の canonical が渡されればそれを、なければ現在ページのURLを基準にする。
const canonicalUrl = withTrailingSlash(
  canonical || new URL(Astro.url.pathname, Astro.site).href
);

// OGP画像（SNSシェア時のサムネイル）＝共通1枚。public/ogp-default.png（1200×630）を配置すること。
const ogImage = 'https://oretachi.me/ogp-default.png';

// 記事/Q&A（published を渡すページ）のみ Article 構造化データを出す。
// about（規約・運営者情報など）は published を渡さない＝Article 扱いにせず日付undefinedを避ける。
const articleLd = published
  ? {
      '@context': 'https://schema.org',
      '@type': 'Article',
      headline: title,
      description,
      datePublished: published,
      dateModified: updated,
      author: { '@type': 'Organization', name: author },
      publisher: { '@type': 'Organization', name: 'オレタチ' },
      mainEntityOfPage: canonicalUrl,
    }
  : null;
// パンくず構造化データ。各 ListItem に item（URL）を持たせる（Search Consoleの "item がありません" 対策）。
// breadcrumb は {name, url} の配列。文字列配列でも後方互換で動く。
const crumbLd = breadcrumb && breadcrumb.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'BreadcrumbList',
      itemListElement: breadcrumb.map((c, i) => {
        const name = typeof c === 'string' ? c : c.name;
        const url = typeof c === 'string' ? null : c.url;
        return { '@type': 'ListItem', position: i + 1, name, ...(url ? { item: url } : {}) };
      }),
    }
  : null;
const faqLd = faq && faq.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faq.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    }
  : null;
---
<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="512x512" href="/app-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Zen+Kaku+Gothic+New:wght@500;700;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@3.7.0/dist/tabler-icons.min.css" />
    <!-- Google tag (gtag.js) / GA4: G-JYDMZ20R7G -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-JYDMZ20R7G"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-JYDMZ20R7G');
    </script>
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="og:site_name" content="オレタチ" />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {articleLd && <script type="application/ld+json" set:html={JSON.stringify(articleLd).replace(/</g, '\\u003c')} />}
    {crumbLd && <script type="application/ld+json" set:html={JSON.stringify(crumbLd).replace(/</g, '\\u003c')} />}
    {faqLd && <script type="application/ld+json" set:html={JSON.stringify(faqLd).replace(/</g, '\\u003c')} />}
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="brand" aria-label="オレタチ"><img src="/app-icon.png" alt="" class="brand-icon" width="36" height="36" /><span class="brand-name">オレタチ</span></a>
        <span class="site-tagline">離婚に直面した男性へ。<br />やること・読みもの・相談先を、ひとつに。</span>
        <nav class="site-nav"><a href="/articles">記事</a><a href="/qa">Q&amp;A</a><a href="/shindan">初動ナビ</a></nav>
      </div>
    </header>
    <main><slot /></main>
    <footer class="site-footer">
      <div class="footer-inner">
        <p class="foot-about">『オレタチ』は、離婚で独りになった男性が、もう一度前を向くための情報と居場所です。ひとりで抱え込まずにすむ場所を、男性の目線でつくっています。</p>
        <nav class="foot-nav"><a href="/about">オレタチとは</a><a href="/about/operator">運営者情報</a><a href="/about/editorial">編集方針</a><a href="/about/privacy">プライバシーポリシー</a><a href="/about/terms">利用規約</a></nav>
        <p>&copy; オレタチ</p>
      </div>
    </footer>
    <script is:inline>
      // 記事内テーブルのうち「3列以上 かつ 長文セルあり」のものだけ、モバイルでカード型に積み替える。
      // 簡易なテーブル（2列・短文）は従来どおりテーブル表示のまま。
      document.querySelectorAll('.content table').forEach(function (t) {
        var ths = [].map.call(t.querySelectorAll('thead th'), function (th) { return th.textContent.trim(); });
        if (!ths.length) return;
        var maxLen = 0;
        [].forEach.call(t.querySelectorAll('tbody td'), function (td) {
          maxLen = Math.max(maxLen, (td.textContent || '').trim().length);
        });
        if (ths.length < 3 || maxLen < 22) return; // 簡易なテーブルはそのまま
        [].forEach.call(t.querySelectorAll('tbody tr'), function (tr) {
          [].forEach.call(tr.children, function (td, i) { if (ths[i]) td.setAttribute('data-label', ths[i]); });
        });
        t.classList.add('stacked');
      });
    </script>
  </body>
</html>
