---
// Q&A詳細レイアウト。Q → 回答/解説/対策（本文）→「役に立った」→ 関連。
import BaseLayout from './BaseLayout.astro';
const { entry } = Astro.props;
const d = entry.data;
---
<BaseLayout
  title={`${d.question}｜オレタチ Q&A`}
  description={d.description}
  canonical={d.canonical}
  published={d.published}
  updated={d.updated}
  author={d.author}
  breadcrumb={["ホーム", "Q&A", d.category]}
  faq={[{ q: d.question, a: d.description }]}
>
  <article class="qa">
    <p class="qa-badge">Q</p>
    <h1>{d.question}</h1>
    <p class="qa-cats"><span class="chip">{d.category}</span>{(d.tags || []).map((t) => <span class="chip ghost">{t}</span>)}</p>
    <div class="content"><slot /></div>
    <div class="helpful">
      <p class="helpful-q">この回答、役に立ったか？</p>
      <button type="button" disabled>助かった</button>
      <button type="button" disabled>うーん、もう一歩</button>
      <small>※評価は公開後に有効化（個人を特定する情報は記録しない）</small>
    </div>
    {d.disclaimer && <p class="disclaimer">{d.disclaimer}</p>}
    <p class="back"><a href="/qa">← ほかのQ&amp;Aも見る（お前だけじゃない）</a></p>
  </article>
</BaseLayout>
