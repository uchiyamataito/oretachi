---
// 記事を1ページずつ自動生成。URL = 記事ファイル名（= スラッグ）。回遊レコメンドも算出して渡す。
import { getCollection } from 'astro:content';
import ArticleLayout from '../layouts/ArticleLayout.astro';
import { buildPool, recommend } from '../data/reco';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  const qas = await getCollection('qa');
  const pool = buildPool(articles, qas);
  return articles.map((entry) => {
    const cur = pool.find((p) => p.type === 'article' && p.slug === entry.slug);
    const recos = cur ? recommend(pool, cur) : { related: [], next: [] };
    return { params: { slug: entry.slug }, props: { entry, recos } };
  });
}

const { entry, recos } = Astro.props;
const { Content, headings } = await entry.render();
---
<ArticleLayout entry={entry} headings={headings} recos={recos}>
  <Content />
</ArticleLayout>
