---
// 記事一覧（ブラウズ）。テーマ（複数選択）×段階（時系列）×キーワードで絞り込む。
// キーワードはタイトル/タグ・説明/本文を重み付けした"関連度つき"検索（クライアント側のみ・URLは増やさない）。
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { AMETA, THEMES, PHASES } from '../data/meta';

const all = (await getCollection('articles')).sort((a, b) =>
  a.data.published < b.data.published ? 1 : -1
);
// 本文も検索対象に。Markdown記号を軽く除去し小文字化（関連度づけ用）。
const strip = (s = '') =>
  s.replace(/```[\s\S]*?```/g, ' ')
   .replace(/<!--[\s\S]*?-->/g, ' ')
   .replace(/https?:\/\/\S+/g, ' ')
   .replace(/[#>*`_\[\]()|~]/g, ' ')
   .replace(/\s+/g, ' ')
   .trim().toLowerCase().slice(0, 4000);

const cards = all.map((a) => {
  const m = AMETA[a.slug] || { phases: [], kanshin: [], tag: '記事' };
  return {
    slug: a.slug,
    title: a.data.title,
    img: a.data.hero_image?.src || '',
    tag: m.tag || '記事',
    kanshin: m.kanshin || [],
    phases: m.phases || [],
  };
});
// 検索インデックス（t=タイトル / s=タグ+説明 / b=本文。重み付けに使う）
const sidx = all.map((a) => ({
  slug: a.slug,
  t: (a.data.title || '').toLowerCase(),
  s: `${(a.data.tags || []).join(' ')} ${a.data.description || ''}`.toLowerCase(),
  b: strip(a.body || ''),
}));
---
<BaseLayout
  title="記事一覧｜オレタチ"
  description="離婚を切り出された男性向けの記事一覧。テーマ（お金・手続き・気持ち・子ども・相談）や、今いる段階（切り出し直後・別居・協議調停・成立後）、キーワードから、必要な記事を探せます。"
  canonical="https://oretachi.me/articles"
>
  <div class="listing-head">
    <h1>記事を読む</h1>
    <p>お前に必要なものだけ。テーマと、今いる段階で絞り込んでくれ。</p>
  </div>

  <div class="home">
  <div class="browse" id="browse">
    <input class="kw-search" id="kw" type="search" placeholder="キーワードで探す（例：保険 子ども 財産分与）" aria-label="キーワード検索" />

    <div class="facet">
      <div class="facet-top">
        <span class="facet-label">テーマ（複数選べる）</span>
        <button type="button" class="facet-clear" data-clear="theme" hidden>× クリア</button>
      </div>
      <div class="chips" data-group="theme">
        {THEMES.map((t) => <button type="button" class="ch" data-v={t.v}>{t.t}</button>)}
      </div>
    </div>

    <div class="facet">
      <div class="facet-top">
        <span class="facet-label">今いる段階（時系列）</span>
        <button type="button" class="facet-clear" data-clear="phase" hidden>× クリア</button>
      </div>
      <div class="chips" data-group="phase">
        {PHASES.map((p) => <button type="button" class="ch" data-v={p.v}>{p.t}</button>)}
      </div>
    </div>

    <div class="result-meta">
      <span class="rc" id="count"></span>
      <button type="button" class="clear" id="clear">条件を全てクリア</button>
    </div>
  </div>

  <div class="cards" id="cards">
    {cards.map((a) => (
      <a class="card" href={`/${a.slug}`} data-slug={a.slug} data-kanshin={a.kanshin.join('|')} data-phases={a.phases.join('|')}>
        <div class="thumb">{a.img ? <img src={a.img} alt={a.title} loading="lazy" /> : <span class="thumb-ph" aria-hidden="true"></span>}</div>
        <div class="cbody"><span class="tag1">{a.tag}</span><h3>{a.title}</h3></div>
      </a>
    ))}
  </div>
  <p class="empty-msg" id="empty" hidden>条件に合う記事がなかった。条件を少し緩めてみてくれ。</p>
  </div>

  <script type="application/json" id="sidx" set:html={JSON.stringify(sidx)}></script>
  <script>
    import { initBrowse } from '../scripts/browse.js';
    initBrowse('.card');
  </script>
</BaseLayout>
