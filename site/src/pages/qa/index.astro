---
// Q&A一覧（ブラウズ）。記事一覧と同じ軸＝テーマ（複数選択）×段階（時系列）×キーワード（関連度つき・本文含む）。
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { QMETA, THEMES, PHASES } from '../../data/meta';

const items = (await getCollection('qa')).sort((a, b) => (a.data.published < b.data.published ? 1 : -1));
const strip = (s = '') =>
  s.replace(/```[\s\S]*?```/g, ' ')
   .replace(/<!--[\s\S]*?-->/g, ' ')
   .replace(/https?:\/\/\S+/g, ' ')
   .replace(/[#>*`_\[\]()|~]/g, ' ')
   .replace(/\s+/g, ' ')
   .trim().toLowerCase().slice(0, 4000);

const cards = items.map((q) => {
  const m = QMETA[q.slug] || { phases: [], kanshin: [] };
  return {
    slug: q.slug,
    question: q.data.question,
    description: q.data.description,
    kanshin: m.kanshin || [],
    phases: m.phases || [],
    cat: (m.kanshin && m.kanshin[0]) || '相談', // 差し色用の代表テーマ
  };
});
const sidx = items.map((q) => ({
  slug: q.slug,
  t: (q.data.question || '').toLowerCase(),
  s: `${(q.data.tags || []).join(' ')} ${q.data.description || ''}`.toLowerCase(),
  b: strip(q.body || ''),
}));
---
<BaseLayout
  title="Q&A｜オレタチ"
  description="離婚を切り出された男のための、よくある疑問とその答え。テーマ（お金・手続き・気持ち・子ども・相談）や今いる段階、キーワードから探せる。大丈夫、たいていの疑問はここにある。"
  canonical="https://oretachi.me/qa"
>
  <div class="listing-head">
    <h1>Q&amp;Aを読む</h1>
    <p>お前の疑問に、ズバッと答える。大丈夫、たいていの疑問はここにある。お前だけじゃない。</p>
  </div>

  <div class="browse" id="browse">
    <input class="kw-search" id="kw" type="search" placeholder="キーワードで探す（例：保険 子ども 口座）" aria-label="キーワード検索" />

    <div class="facet">
      <div class="facet-top">
        <span class="facet-label">テーマ（複数選べる）</span>
        <button type="button" class="facet-clear" data-clear="theme" hidden>× クリア</button>
      </div>
      <div class="chips" data-group="theme">
        {THEMES.map((t) => <button type="button" class="ch" data-v={t.v}>{t.t}</button>)}
      </div>
    </div>

    <div class="facet">
      <div class="facet-top">
        <span class="facet-label">今いる段階（時系列）</span>
        <button type="button" class="facet-clear" data-clear="phase" hidden>× クリア</button>
      </div>
      <div class="chips" data-group="phase">
        {PHASES.map((p) => <button type="button" class="ch" data-v={p.v}>{p.t}</button>)}
      </div>
    </div>

    <div class="result-meta">
      <span class="rc" id="count"></span>
      <button type="button" class="clear" id="clear">条件を全てクリア</button>
    </div>
  </div>

  <ul class="qa-grid" id="cards">
    {cards.map((i) => (
      <li class="qa-card" data-slug={i.slug} data-kanshin={i.kanshin.join('|')} data-phases={i.phases.join('|')} data-cat={i.cat}>
        <a href={`/qa/${i.slug}`}>
          <span class="qa-cat">{i.cat}</span>
          <span class="qa-q">Q. {i.question}</span>
          <span class="qa-ex">{i.description}</span>
          <i class="ti ti-chevron-right qa-go" aria-hidden="true"></i>
        </a>
      </li>
    ))}
  </ul>
  <p class="empty-msg" id="empty" hidden>条件に合うQ&amp;Aがなかった。条件を少し緩めてみてくれ。</p>

  <script type="application/json" id="sidx" set:html={JSON.stringify(sidx).replace(/</g, '\\u003c')}></script>
  <script>
    import { initBrowse } from '../../scripts/browse.js';
    initBrowse('.qa-card');
  </script>
</BaseLayout>
