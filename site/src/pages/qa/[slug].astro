---
// Q&Aを1ページずつ自動生成。回遊レコメンドも算出して渡す。
import { getCollection } from 'astro:content';
import QaLayout from '../../layouts/QaLayout.astro';
import { buildPool, recommend } from '../../data/reco';

export async function getStaticPaths() {
  const items = await getCollection('qa');
  const articles = await getCollection('articles');
  const pool = buildPool(articles, items);
  return items.map((entry) => {
    const cur = pool.find((p) => p.type === 'qa' && p.slug === entry.slug);
    const recos = cur ? recommend(pool, cur) : { related: [], next: [] };
    return { params: { slug: entry.slug }, props: { entry, recos } };
  });
}

const { entry, recos } = Astro.props;
const { Content } = await entry.render();
---
<QaLayout entry={entry} recos={recos}><Content /></QaLayout>
