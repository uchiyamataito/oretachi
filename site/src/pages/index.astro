---
// トップ＝入口・案内（IA：記事一覧は /articles に分離）。UX設計=23。
// 静かな共感ヒーロー → オンボ主役（一つ選ぶだけ）→ TODAY → まず読む数本 → 各セクション入口 → 安全網。
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles');
const bySlug = Object.fromEntries(all.map((a) => [a.slug, a]));

const onb = [
  { label: '切り出された直後',   hint: 'まず最初の14日にやること',     icon: 'clock-hour-4',  href: '/rikon-kiridasareta-saisho-14nichi', phase: '切り出された直後', kanshin: '初動' },
  { label: 'お金が不安',         hint: '財産分与・棚卸し・これからのお金', icon: 'coin',         href: '/rikon-okane-checklist',            phase: '', kanshin: 'お金' },
  { label: '子どものこと',       hint: '保険証・児童手当・親権の前提',   icon: 'mood-kid',     href: '/rikon-kodomo-hoken',               phase: '', kanshin: '子ども' },
  { label: 'まだ別れたくない',   hint: '追いすがる前に読んでほしい',     icon: 'heart',        href: '/rikon-mada-wakaretakunai',         phase: 'まだ別れたくない', kanshin: '気持ち' },
  { label: '誰にも言えない',     hint: '一人で抱える前に・相談先',       icon: 'message-circle', href: '/rikon-dansei-soudansaki',         phase: '', kanshin: '相談' },
  { label: '何からか分からない', hint: '気持ち・お金・手続きの全体マップ', icon: 'map-2',       href: '/rikon-nani-kara-hajimeru',         phase: '', kanshin: '全体' },
];

// トップに置くのは"まず読む"3本だけ（全記事は /articles）
const pickSlugs = ['rikon-kiridasareta-saisho-14nichi', 'rikon-nani-kara-hajimeru', 'rikon-dansei-soudansaki'];
const picks = pickSlugs.map((s) => bySlug[s]).filter(Boolean);
---
<BaseLayout
  title="オレタチ｜離婚を切り出された男のための初動ナビ"
  description="離婚を切り出された男性へ。何から考えればいいか分からなくて当然だ。今いちばんしんどいことを一つ選べば、最初の一歩が見つかる。お金・手続き・気持ち・子ども・相談先を男性目線で。"
  canonical="https://oretachi.me/"
>
  <div class="home">

    <!-- 再訪バナー（現在地があればJSで表示） -->
    <a class="welcome" id="welcome" href="/" hidden>
      <span class="wb-txt">おかえり。前回は<b id="wb-label">―</b>が気がかりだったね。</span>
      <span class="wb-go">続きを見る →</span>
    </a>

    <!-- 静かな共感ヒーロー -->
    <section class="hero2">
      <p class="eyebrow">離婚を切り出された男のための、初動ナビ</p>
      <h1>大丈夫だ。<br>まず、一緒に整理しよう。</h1>
      <p class="sub">何から考えればいいか分からなくて、当然だ。全部を一度に背負わなくていい。<strong>今いちばんしんどいことを、ひとつだけ</strong>選んでくれ。そこから始めよう。</p>
    </section>

    <!-- オンボ主役：今いちばんしんどいのは？ -->
    <div class="onb-head">今、いちばんしんどいのは？</div>
    <p class="onb-note">ひとつ選ぶだけでいい。うまく言葉にできなくて大丈夫。</p>
    <nav class="onb" aria-label="今の状況から始める">
      {onb.map((o) => (
        <a class="onb-tile" href={o.href} data-phase={o.phase} data-kanshin={o.kanshin} data-label={o.label}>
          <i class={`ti ti-${o.icon}`} aria-hidden="true"></i>
          <span class="ol">{o.label}</span>
          <span class="oh">{o.hint}</span>
        </a>
      ))}
    </nav>
    <a class="onb-talk" href="/rikon-nani-kara-hajimeru" data-kanshin="全体" data-label="何から始める">
      <i class="ti ti-messages" aria-hidden="true"></i>うまく言葉にできない時は、ここから<span class="badge">準備中</span>
    </a>

    <!-- TODAY -->
    <div class="today">
      <div class="k"><i class="ti ti-sun-low" aria-hidden="true"></i>TODAY ― 今日の、たった一つ</div>
      <div class="t">返事を急がない。「少し考えたい」で十分だ。</div>
    </div>

    <!-- まず読むなら（厳選3本のみ。全記事は /articles） -->
    <div class="sh"><h2>まず読むなら</h2><a href="/articles">記事をすべて見る →</a></div>
    <div class="cards">
      {picks.map((a) => (
        <a class="card" href={`/${a.slug}`}>
          <div class="thumb"><img src={a.data.hero_image?.src} alt={a.data.title} loading="lazy" /></div>
          <div class="cbody"><h3>{a.data.title}</h3></div>
        </a>
      ))}
    </div>

    <!-- 各セクションへの入口 -->
    <div class="nav-cards">
      <a class="nav-card" href="/articles">
        <i class="ti ti-news" aria-hidden="true"></i>
        <span class="nc-body"><span class="nc-t">記事を読む</span><span class="nc-d">お金・手続き・気持ち・子ども</span></span>
        <i class="ti ti-chevron-right nc-go" aria-hidden="true"></i>
      </a>
      <a class="nav-card" href="/qa">
        <i class="ti ti-help-circle" aria-hidden="true"></i>
        <span class="nc-body"><span class="nc-t">Q&amp;Aを見る</span><span class="nc-d">よくある疑問に、一問即答</span></span>
        <i class="ti ti-chevron-right nc-go" aria-hidden="true"></i>
      </a>
      <a class="nav-card" href="/rikon-dansei-soudansaki">
        <i class="ti ti-lifebuoy" aria-hidden="true"></i>
        <span class="nc-body"><span class="nc-t">相談先・窓口</span><span class="nc-d">一人で抱える前に</span></span>
        <i class="ti ti-chevron-right nc-go" aria-hidden="true"></i>
      </a>
    </div>

    <!-- つらい時の安全網 -->
    <div class="safety">
      <b>つらくて動けない時は、無理しないでくれ。</b> 眠れない・消えてしまいたいと感じるほどなら、いのちより大切なものはない。よりそいホットライン <b>0120-279-338</b>（24時間・無料）など、声を出さなくても頼れる窓口がある。詳しくは <a href="/rikon-dansei-soudansaki">相談先のページ</a>へ。
    </div>

  </div>

  <script>
    // 現在地の保存（オンボtileクリック）＋再訪バナー（軽量・PIIなし）
    const KEY = 'oretachi_state';
    const read = () => { try { return JSON.parse(localStorage.getItem(KEY) || 'null'); } catch { return null; } };
    document.querySelectorAll('.home .onb-tile, .home .onb-talk').forEach((el) => {
      el.addEventListener('click', () => {
        const prev = read() || {};
        const phase = el.getAttribute('data-phase') || prev.phase || '';
        const kanshin = el.getAttribute('data-kanshin') || '';
        const list = Array.from(new Set([...(prev.kanshin || []), kanshin].filter(Boolean)));
        const state = { phase, kanshin: list, next: el.getAttribute('href'), label: el.getAttribute('data-label') || '', ts: Date.now() };
        try { localStorage.setItem(KEY, JSON.stringify(state)); } catch {}
      });
    });
    const st = read();
    if (st && (st.label || (st.kanshin && st.kanshin.length))) {
      const w = document.getElementById('welcome');
      const lab = document.getElementById('wb-label');
      if (w && lab) {
        lab.textContent = st.label || (st.kanshin && st.kanshin[0]) || 'あのこと';
        if (st.next) w.setAttribute('href', st.next);
        w.removeAttribute('hidden');
      }
    }
  </script>
</BaseLayout>
