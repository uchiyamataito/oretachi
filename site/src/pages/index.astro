---
// トップ＝マイページ（24スペック）。未オンボ=大導線→5問モーダル。オンボ済=状態依存アコーディオン時系列＋記事/Q&Aレコメンド。
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { AMETA, QMETA } from '../data/meta';

const arts = await getCollection('articles');
const qas = await getCollection('qa');

const adata = arts.map((a) => ({ slug: a.slug, title: a.data.title, img: a.data.hero_image?.src || '', published: a.data.published, ...(AMETA[a.slug] || { phases: [], kanshin: [], kids: false, pick: false, rank: 99, tag: '記事' }) }));
const qdata = qas.map((q) => ({ slug: q.slug, q: q.data.question, d: q.data.description, ...(QMETA[q.slug] || { phases: [], kanshin: [] }) }));
const newest = [...arts].sort((a, b) => (a.data.published < b.data.published ? 1 : -1));
---
<BaseLayout
  title="オレタチ｜離婚を切り出された男のための初動ナビ"
  description="離婚を切り出された男のためのマイページ型ナビ。5つの質問で、お前の現在地（時系列）に合わせて、次にやること・お前に合う記事とQ&Aを出す。ひとりじゃない。"
  canonical="https://oretachi.me/"
>
  <div class="home">
    <div id="greet-slot"></div>
    <div id="journey-slot"></div>

    <!-- 未オンボ＝大導線（エンプティステート） -->
    <div class="emptyhero" id="emptyhero">
      <div class="ghost"></div>
      <div class="eh-k">YOUR MAP</div>
      <div class="eh-t">お前の“現在地マップ”は、まだぼんやりしている。</div>
      <div class="eh-s">何から考えればいいか分からなくて、当たり前だ。全部を一度に背負わなくていい。<strong>5つの質問（約30秒）</strong>に答えてくれりゃ、お前の状況に合わせた<strong>“やる順番（時系列）”</strong>と、次に読むべき記事・Q&Aが並ぶ。一緒にやろう。</div>
      <button class="eh-btn" id="start-onb"><i class="ti ti-route" aria-hidden="true"></i>お前の現在地をつくる</button>
      <div class="eh-mini">名前も連絡先も聞かない。答えはこの端末の中だけに残る。</div>
      <a class="eh-about" href="/about">「オレタチ」って、どんな場所？</a>
    </div>

    <div id="rails">
      <div class="sh"><h2>記事</h2><a href="/articles">すべて見る →</a></div>
      <div class="cards">
        {newest.map((a) => (
          <a class="card" href={`/${a.slug}`}>
            <div class="thumb">{a.data.hero_image?.src ? <img src={a.data.hero_image.src} alt={a.data.title} loading="lazy" /> : <span class="thumb-ph" aria-hidden="true"></span>}</div>
            <div class="cbody"><span class="tag1">{(AMETA[a.slug] || {}).tag || '記事'}</span><h3>{a.data.title}</h3></div>
          </a>
        ))}
      </div>
    </div>

    <div class="nav-cards">
      <a class="nav-card" href="/articles"><i class="ti ti-news" aria-hidden="true"></i><span class="nc-body"><span class="nc-t">記事を読む</span><span class="nc-d">お金・手続き・気持ち・子ども</span></span><i class="ti ti-chevron-right nc-go" aria-hidden="true"></i></a>
      <a class="nav-card" href="/qa"><i class="ti ti-help-circle" aria-hidden="true"></i><span class="nc-body"><span class="nc-t">Q&amp;Aを見る</span><span class="nc-d">同じ状況の疑問に、一問即答</span></span><i class="ti ti-chevron-right nc-go" aria-hidden="true"></i></a>
    </div>

    <div class="safety">
      <b>つらくて動けない時は、無理しないでくれ。</b> 眠れない・消えてしまいたいと感じるほどなら、いのちより大切なものはない。よりそいホットライン <b>0120-279-338</b>（24時間・無料）など、声を出さなくても頼れる窓口がある。
      <a class="safety-link" href="/rikon-dansei-soudansaki#危機のときは迷わずここへ命が最優先"><i class="ti ti-lifebuoy" aria-hidden="true"></i>相談先・窓口を見る</a>
    </div>
  </div>

  <!-- オンボ・モーダル -->
  <div class="onbm" id="onbm" role="dialog" aria-modal="true" aria-label="現在地をつくる">
    <div class="ov" id="onbm-ov"></div>
    <div class="sheet">
      <div class="bar"><div class="dots" id="onbm-dots"></div><button class="close" id="onbm-close" aria-label="閉じる">×</button></div>
      <div id="onbm-q"></div>
    </div>
  </div>

  <script type="application/json" id="adata" set:html={JSON.stringify(adata).replace(/</g, '\\u003c')}></script>
  <script type="application/json" id="qdata" set:html={JSON.stringify(qdata).replace(/</g, '\\u003c')}></script>
  <script>
    const KEY = 'oretachi_state';
    const read = () => { try { return JSON.parse(localStorage.getItem(KEY) || 'null'); } catch { return null; } };
    const A = JSON.parse(document.getElementById('adata')?.textContent || '[]');
    const Q = JSON.parse(document.getElementById('qdata')?.textContent || '[]');
    const esc = (s) => String(s == null ? '' : s).replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
    const safeUrl = (u) => { const s = String(u == null ? '' : u); return /^(https?:|\/|#|mailto:)/i.test(s) ? s : '#'; };

    // ===== オンボ設問（24§1） =====
    const QUESTIONS = [
      { id: 'phase', h: '今、お前はどの段階にいる？', s: 'まずは現在地を教えてくれ。', multi: false, opts: [
        { v: '切り出された直後', t: '妻に切り出されたばかり' }, { v: '別居', t: '別居中／別居を考えている' },
        { v: '協議・調停中', t: '協議・調停を進めている' }, { v: '成立後', t: 'もう離婚は成立した' } ] },
      { id: 'route', h: 'これからの気持ちに、近いのは？', s: 'この答えで、出す情報を変える。', multi: false,
        opts: [
          { v: 'fukuen', t: 'まだ別れたくない・やり直したい' }, { v: 'rikon', t: '離婚に向けて進めたい' }, { v: 'mitei', t: 'まだ決められない' } ],
        // フェーズ別の文言出し分け。route値（fukuen/rikon/mitei）は不変＝下流ロジック（時系列・レコメンド）に無影響。
        // 表示ラベルのみ差し替える。未定義フェーズは既定optsにフォールバックするため、将来のフェーズ追加でも壊れない。
        optsByPhase: {
          // 成立後は復縁トラック（fukuen）に入ると時系列が破綻するため、再出発/整理の2択に絞る。
          '成立後': [
            { v: 'rikon', t: '前を向いて再出発したい' }, { v: 'mitei', t: '気持ちの整理が、まだつかない' } ],
        },
      },
      { id: 'kids', h: '子どもはいるか？', s: '', multi: false, opts: [
        { v: 'minor', t: '未成年の子がいる' }, { v: 'adult', t: '成人の子のみ' }, { v: 'none', t: 'いない' } ] },
      { id: 'trouble', h: '今の話し合いの状況は？', s: 'お前の安全と緊急度を確かめるためだけに使う。', multi: false,
        opts: [
          { v: 'calm', t: 'まだ／円満に進みそう' }, { v: 'dispute', t: '揉めている・相手が弁護士を立てた' }, { v: 'danger', t: '暴力など、身の危険がある' }, { v: 'unknown', t: 'まだ、どうなるか分からない' } ],
        // 成立後は「話し合い」終了前提に合わせ、見出し・選択肢を離婚後の文脈に出し分け（値calm/dispute/danger/unknownは不変）。
        hByPhase: { '成立後': '離婚後、相手とのやり取りは？' },
        optsByPhase: {
          '成立後': [
            { v: 'calm', t: '落ち着いている／連絡はほぼない' }, { v: 'dispute', t: '養育費・面会などで揉めている' }, { v: 'danger', t: '暴力・つきまといなど、身の危険がある' }, { v: 'unknown', t: 'まだ、どうなるか分からない' } ],
        },
      },
      { id: 'kanshin', h: '今、いちばん不安なのは？', s: 'いくつ選んでもいい。', multi: true, opts: [
        { v: 'お金', t: 'お金・財産' }, { v: '手続き', t: '各種手続き' }, { v: '気持ち', t: '気持ち・メンタル' }, { v: '子ども', t: '子どものこと' }, { v: '相談', t: '相談相手がいない' } ] },
    ];

    // ===== 状態依存タイムライン定義（24§3） =====
    // h は記事内の該当セクション（見出しID＝github-slugger）まで指してアンカー遷移させる
    const PH_RIKON = [
      { key: '切り出された直後', name: '初動・心の整理', desc: 'まず急がない。最初の14日。', todos: [
        { l: '返事を急がない｜最初の14日でやること', h: '/rikon-kiridasareta-saisho-14nichi#まず押さえる3つ' },
        { l: '妻に切り出されたら何て返す？NG対応と一言', h: '/rikon-kaesu-kotoba' },
        { l: '健康保険など“期限のある手続き”を確認', h: '/rikon-kenkohoken-tetsuzuki#まず押さえる3つ' },
        { l: 'つらい時は一人で抱えない｜相談先', h: '/rikon-dansei-soudansaki#無理なく踏める最初の一歩' } ] },
      { key: '別居', name: '別居・生活とお金', desc: '生活基盤とお金を守る。', todos: [
        { l: '別居の期間・生活費（婚姻費用）とNG行動', h: '/rikon-bekkyo' },
        { l: 'お金の棚卸し・証拠の確保', h: '/rikon-okane-checklist#-棚卸し資産プラスと負債マイナスを全部出す' },
        { l: '共有口座を動かす前に', h: '/qa/rikon-kyouyu-kouza-ugokasu' },
        { l: '家を出るべきか迷ったら', h: '/qa/rikon-ie-deru-beki' },
        { l: '子の保険証・児童手当', h: '/rikon-kodomo-hoken#-子どもの健康保険保険証資格', cond: 'kids' } ] },
      { key: '協議・調停中', name: '協議・調停', desc: '話し合いの進め方。', todos: [
        { l: '何から進める？全体マップ', h: '/rikon-nani-kara-hajimeru#束をほどくやることは5つのかたまりに収まる' },
        { l: '財産分与で何が分けられる？対象・対象外', h: '/rikon-zaisan-bunyo-taishou' },
        { l: '相談先・専門家の選び方', h: '/rikon-dansei-soudansaki#既存の相談窓口を役割と限界で正直に整理する' },
        { l: '弁護士など専門家への相談を考える', h: '/rikon-dansei-soudansaki#既存の相談窓口を役割と限界で正直に整理する', cond: 'dispute', kind: 'legal' },
        { l: '父親は親権を取れる？確率・条件と今からできること', h: '/rikon-shinken-chichioya', cond: 'kids' },
        { l: '親権の前提を知る（子どもの手続き）', h: '/rikon-kodomo-hoken#親権が起点でもその判断には私たちは踏み込めない', cond: 'kids' } ] },
      { key: '成立後', name: '成立・名義変更', desc: '手続きを片づける。', todos: [
        { l: '健康保険の切替', h: '/rikon-kenkohoken-tetsuzuki#あなたはどのケース早見表' },
        { l: '年金の手続き', h: '/rikon-nenkin-tetsuzuki#誰が何をどこでやるか一枚で' },
        { l: '保険の受取人を変える', h: '/rikon-seimeihoken-uketorinin#手順3ステップ' },
        { l: '扶養・税金はどう変わる', h: '/rikon-fuyou-zeikin#-健康保険の扶養を外す' } ] },
      { key: '再出発', name: '再出発', desc: '生活を立て直す。', todos: [
        { l: '離婚した男の再出発｜心・生活・お金の立て直し', h: '/rikon-saishuppatsu' },
        { l: '離婚して後悔する？データと立ち直り方', h: '/rikon-koukai' },
        { l: '一人で抱えない・相談先', h: '/rikon-dansei-soudansaki#無理なく踏める最初の一歩' } ] },
    ];
    const PH_FUKUEN = [
      { key: '切り出された直後', name: '初動・心の整理', desc: 'まず落ち着く。', todos: [
        { l: '最初の14日でやること・やってはいけないこと', h: '/rikon-kiridasareta-saisho-14nichi#やるべきとやってはいけないを一枚で' },
        { l: '妻に切り出されたら何て返す？NG対応と一言', h: '/rikon-kaesu-kotoba' },
        { l: '頭が真っ白でも、それで普通だ', h: '/qa/rikon-kiridasareta-atama-masshiro' } ] },
      { key: '修復', name: '関係修復を試みる', desc: '追わない。冷却と、誠実な対話。', todos: [
        { l: '妻と復縁・関係を修復したい｜冷却期間と連絡・NG', h: '/rikon-fukuen-shuufuku' },
        { l: '切り出される夫の特徴とサイン｜今から効くこと', h: '/rikon-kiridasareru-tokuchou-sain' },
        { l: 'まだ別れたくない人へ｜NG行動とやること', h: '/rikon-mada-wakaretakunai#やるべきとやってはいけないを一枚で' },
        { l: '理由を問い詰めない', h: '/qa/rikon-riyuu-toitsumeru' },
        { l: '一人で抱えない・相談先', h: '/rikon-dansei-soudansaki#無理なく踏める最初の一歩' } ] },
      { key: '合流', name: 'もし離婚に進むことになったら', desc: '念のため、進む場合の備えも。', todos: [
        { l: '何から始める？全体マップ', h: '/rikon-nani-kara-hajimeru#束をほどくやることは5つのかたまりに収まる' } ] },
    ];

    // ====== モーダル制御 ======
    const modal = document.getElementById('onbm');
    const qWrap = document.getElementById('onbm-q');
    const dotsEl = document.getElementById('onbm-dots');
    let answers = {}, idx = 0;
    const openModal = () => { answers = {}; idx = 0; modal.classList.add('open'); document.body.style.overflow = 'hidden'; renderQ(); };
    const closeModal = () => { modal.classList.remove('open'); document.body.style.overflow = ''; };
    document.getElementById('start-onb')?.addEventListener('click', openModal);
    document.getElementById('onbm-close')?.addEventListener('click', closeModal);
    document.getElementById('onbm-ov')?.addEventListener('click', closeModal);

    function renderQ() {
      dotsEl.innerHTML = QUESTIONS.map((_, i) => `<span class="${i <= idx ? 'on' : ''}"></span>`).join('');
      const q = QUESTIONS[idx];
      const sel = answers[q.id];
      // フェーズ別の出し分け（見出し・選択肢）。該当なければ既定値にフォールバック。
      const qH = (q.hByPhase && q.hByPhase[answers.phase]) || q.h;
      const qOpts = (q.optsByPhase && q.optsByPhase[answers.phase]) || q.opts;
      const opts = qOpts.map((o) => {
        const on = q.multi ? (sel || []).includes(o.v) : sel === o.v;
        return `<button class="opt ${on ? 'sel' : ''}" data-v="${esc(o.v)}">${esc(o.t)}<i class="ti ti-check ck"></i></button>`;
      }).join('');
      const isLast = idx === QUESTIONS.length - 1;
      qWrap.innerHTML =
        `<div class="qh">${esc(qH)}</div>${q.s ? `<div class="qs">${esc(q.s)}</div>` : ''}` +
        `<div class="opts">${opts}</div>` +
        `<div class="nav">${idx > 0 ? '<button class="back" id="q-back">戻る</button>' : ''}<button class="next" id="q-next" ${(!q.multi && !sel) || (q.multi && !(sel && sel.length)) ? 'disabled' : ''}>${isLast ? 'これでつくる' : '次へ'}</button></div>` +
        (q.id === 'kanshin' || q.id === 'trouble' ? '' : `<button class="skip" id="q-skip">スキップ</button>`);
      qWrap.querySelectorAll('.opt').forEach((b) => b.addEventListener('click', () => {
        const v = b.getAttribute('data-v');
        if (q.multi) { const cur = new Set(answers[q.id] || []); cur.has(v) ? cur.delete(v) : cur.add(v); answers[q.id] = [...cur]; renderQ(); }
        else { answers[q.id] = v; setTimeout(advance, 160); }
      }));
      document.getElementById('q-next')?.addEventListener('click', advance);
      document.getElementById('q-back')?.addEventListener('click', () => { idx = Math.max(0, idx - 1); renderQ(); });
      document.getElementById('q-skip')?.addEventListener('click', advance);
    }
    function advance() { if (idx < QUESTIONS.length - 1) { idx++; renderQ(); } else { finish(); } }
    function finish() {
      const st = {
        phase: answers.phase || '切り出された直後', route: answers.route || 'mitei', kids: answers.kids || 'none',
        trouble: answers.trouble || 'calm', kanshin: answers.kanshin || [],
        history: (read() || {}).history || [], done: (read() || {}).done || [], label: (answers.kanshin && answers.kanshin[0]) || answers.phase || '', ts: Date.now(),
      };
      localStorage.setItem(KEY, JSON.stringify(st));
      try { sessionStorage.removeItem('oretachi_cue_sess'); localStorage.removeItem('oretachi_cue_last'); } catch (e) {}
      closeModal(); renderMypage(st); showDotTip();
    }

    // オンボ完了直後に1回だけ、「ドットで今ここを動かせる」ことを説明する小モーダル。
    function showDotTip() {
      try { if (localStorage.getItem('oretachi_tip_dot')) return; } catch (e) {}
      const wrap = document.createElement('div');
      wrap.className = 'dottip';
      wrap.innerHTML = '<div class="dottip-card" role="dialog" aria-modal="true"><div class="dottip-t">現在地は、あとから動かせる</div><div class="dottip-d">状況が進んだら、時系列の左の<span class="dottip-dot"></span>（丸）をタップして「今ここ」を移してくれ。今のお前に合った“やること”に並び替わる。</div><button class="dottip-ok" type="button">わかった</button></div>';
      document.body.appendChild(wrap);
      const close = () => { try { localStorage.setItem('oretachi_tip_dot', '1'); } catch (e) {} wrap.remove(); };
      wrap.querySelector('.dottip-ok')?.addEventListener('click', close);
      wrap.addEventListener('click', (e) => { if (e.target === wrap) close(); });
    }

    // ====== レンダリング ======
    const acard = (a) => `<a class="rcard" href="${esc(safeUrl('/' + a.slug))}"><div class="rthumb">${a.img ? `<img src="${esc(safeUrl(a.img))}" alt="${esc(a.title)}" loading="lazy">` : '<span class="thumb-ph" aria-hidden="true"></span>'}</div><div class="rb"><span class="rtag">${esc(a.tag)}</span><div class="rt">${esc(a.title)}</div></div></a>`;
    const qcard = (x) => { const cat = (x.kanshin && x.kanshin[0]) || '相談'; return `<a class="qcard" href="${esc(safeUrl('/qa/' + x.slug))}" data-cat="${esc(cat)}"><span class="qcat">${esc(cat)}</span><div class="qq">Q. ${esc(x.q)}</div><span class="qa">${esc(x.d)}</span><i class="ti ti-chevron-right qgo" aria-hidden="true"></i></a>`; };
    const railA = (t, note, items) => items.length ? `<section class="rail"><div class="rail-head"><h2>${esc(t)}</h2>${note ? `<span class="rh-note">${esc(note)}</span>` : ''}</div><div class="rail-scroller">${items.map(acard).join('')}</div></section>` : '';
    const railQ = (t, note, items) => items.length ? `<section class="rail"><div class="rail-head"><h2>${esc(t)}</h2>${note ? `<span class="rh-note">${esc(note)}</span>` : ''}</div><div class="rail-scroller">${items.map(qcard).join('')}</div></section>` : '';
    const railRank = (t, items) => items.length ? `<section class="rail"><div class="rail-head"><h2>${esc(t)}</h2><span class="rh-note">いま読まれている順</span></div><div class="rank-ol">${items.map((a, i) => `<a class="rank-item ${i === 0 ? 'top' : ''}" href="${esc(safeUrl('/' + a.slug))}"><span class="rt">${esc(a.title)}</span></a>`).join('')}</div></section>` : '';

    // 時系列の合図（チェブロン点滅）を出すべきか：新セッション開始時／オンボやり直し時／前回表示から24時間経過時のみ。
    function shouldCueNow() {
      try {
        const now = Date.now();
        const sess = sessionStorage.getItem('oretachi_cue_sess');
        const last = parseInt(localStorage.getItem('oretachi_cue_last') || '0', 10);
        const show = !sess || (now - last >= 86400000);
        if (show) { sessionStorage.setItem('oretachi_cue_sess', '1'); localStorage.setItem('oretachi_cue_last', String(now)); }
        return show;
      } catch (e) { return true; }
    }
    function renderMypage(st, openKey) {
      document.getElementById('emptyhero').style.display = 'none';
      const railsEl = document.getElementById('rails');
      st.done = st.done || [];                 // 手動チェック（本人が完了をON/OFF）
      const doneSet = new Set(st.done);
      // おかえり
      const lab = st.label || st.phase || 'あのこと';
      document.getElementById('greet-slot').innerHTML =
        `<div class="greet"><div class="greet-top"><div class="gt">おかえり</div><button class="reset" id="reset-state">最初から</button></div><div class="gs">お前の現在地に合わせて、やることと読みものを並べたぞ。</div></div>`;
      document.getElementById('reset-state')?.addEventListener('click', () => { localStorage.removeItem(KEY); location.reload(); });

      // タイムライン（ルート選択＋現在地＋アコーディオン）
      const fukuen = st.route === 'fukuen';
      const phases = fukuen ? PH_FUKUEN : PH_RIKON;
      let ci = fukuen ? (st.phase === '切り出された直後' ? 0 : 1) : Math.max(0, phases.findIndex((p) => p.key === st.phase));
      if (ci < 0) ci = 0;
      // 手動の現在地オーバーライド（curKey）。本人がタップで「今ここ」を移動できる。
      // トラック（離婚/復縁）に存在するキーのみ採用。無効なら従来のphase由来にフォールバック。
      if (st.curKey) { const k = phases.findIndex((p) => p.key === st.curKey); if (k >= 0) ci = k; }
      const visited = new Set(st.history || []);
      const showCue = shouldCueNow();
      const phaseHtml = phases.map((p, i) => {
        const cls = i < ci ? 'done' : (i === ci ? 'current' : 'future');
        const openCls = (openKey && p.key === openKey) ? ' open' : '';
        let todos = (p.todos || []).filter((t) => !t.cond || (t.cond === 'kids' && st.kids === 'minor') || (t.cond === 'dispute' && (st.trouble === 'dispute' || st.trouble === 'danger')));
        // 危険時は安全を最上部に
        if (i === ci && st.trouble === 'danger') todos = [{ l: 'まず身の安全を｜DV相談プラス 0120-279-889（24時間）', h: '/rikon-dansei-soudansaki#危機のときは迷わずここへ命が最優先', kind: 'safe' }, ...todos];
        const todoHtml = todos.map((t) => {
          if (t.coming) return `<div class="todo coming"><i class="ti ti-pencil ci"></i><span class="tt">${esc(t.l)}<span class="cm">準備中</span></span></div>`;
          const dkey = `${p.name}|${t.l}`;
          const done = doneSet.has(dkey);
          const kind = t.kind === 'safe' ? ' safe' : (t.kind === 'legal' ? ' legal' : '');
          return `<div class="todo${done ? ' done2' : ''}${kind}"><button class="tk" type="button" data-dk="${esc(dkey)}" aria-label="完了の切り替え"></button><a class="tlink" href="${esc(safeUrl(t.h))}"><span class="tt">${esc(t.l)}</span><i class="ti ti-chevron-right tg"></i></a></div>`;
        }).join('');
        // 現在地の操作：他フェーズ＝「ここを今ここにする」／現フェーズで全完了＝「次へ進む」をやさしく提案
        const realTodos = todos.filter((t) => !t.coming);
        const allDone = realTodos.length > 0 && realTodos.every((t) => doneSet.has(`${p.name}|${t.l}`));
        // 現在地の切替は各フェーズのドット(jdot)タップで行う（下のハンドラ）。
        // 現フェーズでtodoを全完了したときだけ、やさしく次へ進む提案を出す。
        let actHtml = '';
        if (i === ci && i < phases.length - 1 && allDone) {
          actHtml = `<div class="jph-advance-wrap"><span class="jph-advance-msg">この段階は一通り済んだな。</span><button class="jph-advance" type="button" data-key="${esc(phases[i + 1].key)}"><i class="ti ti-arrow-down" aria-hidden="true"></i>「${esc(phases[i + 1].name)}」へ進む</button></div>`;
        }
        return `<div class="jph ${cls}${openCls}"><span class="jph-line"></span><button class="jdot" type="button" data-key="${esc(p.key)}" aria-label="「${esc(p.name)}」を今ここにする"></button><div class="jph-main"><button class="jph-head" data-i="${i}"><span class="jph-nm">${esc(p.name)}</span>${i === ci ? '<span class="jph-now">今ここ</span>' : ''}<i class="ti ti-chevron-down jph-cv${i === ci && showCue ? ' cue' : ''}"></i></button><div class="jph-desc">${esc(p.desc)}</div>${actHtml}<div class="jph-body">${todoHtml}</div></div></div>`;
      }).join('');
      document.getElementById('journey-slot').innerHTML =
        `<div class="journey jrny"><div class="jk"><i class="ti ti-route"></i>お前の時系列｜現在地と、やること</div><div class="jsub">各フェーズはタップで開ける。左の<span class="jsub-dot" aria-hidden="true"></span>をタップすると「今ここ」を動かせる。</div><div class="legend"><span><i class="leg-dot d-cur"></i>今ここ・要注意</span><span><i class="leg-dot d-done"></i>通過</span></div>${phaseHtml}</div>`;
      document.querySelectorAll('#journey-slot .jph-head').forEach((b) => b.addEventListener('click', () => { b.closest('.jph').classList.toggle('open'); const cv = b.querySelector('.jph-cv'); if (cv) cv.classList.remove('cue'); }));
      // ドット(jdot)タップで「今ここ」を切り替え。移動先を開いた状態で再描画。
      document.querySelectorAll('#journey-slot .jdot').forEach((b) => b.addEventListener('click', (e) => {
        e.preventDefault(); e.stopPropagation();
        const k = b.getAttribute('data-key'); if (!k) return;
        st.curKey = k; localStorage.setItem(KEY, JSON.stringify(st)); renderMypage(st, k);
      }));
      // 手動チェック（閲覧≠完了。本人がON/OFF。記事リンクには遷移しない）
      document.querySelectorAll('#journey-slot .todo .tk').forEach((b) => b.addEventListener('click', (e) => {
        e.preventDefault(); e.stopPropagation();
        const k = b.getAttribute('data-dk');
        doneSet.has(k) ? doneSet.delete(k) : doneSet.add(k);
        st.done = [...doneSet];
        localStorage.setItem(KEY, JSON.stringify(st));
        b.closest('.todo').classList.toggle('done2');
      }));
      // 「今ここ」を手動で移動（ここにする／次へ進む）。移動先フェーズを開いた状態で再描画。
      document.querySelectorAll('#journey-slot .jph-setcur, #journey-slot .jph-advance').forEach((b) => b.addEventListener('click', (e) => {
        e.preventDefault(); e.stopPropagation();
        st.curKey = b.getAttribute('data-key');
        localStorage.setItem(KEY, JSON.stringify(st));
        renderMypage(st, st.curKey);
      }));

      // レコメンド（重複なし：記事プール／Q&Aプールで別管理）
      const shownA = new Set(), shownQ = new Set();
      const takeA = (list, n) => { const o = []; for (const a of list) { if (o.length >= n) break; if (shownA.has(a.slug)) continue; shownA.add(a.slug); o.push(a); } return o; };
      const takeQ = (list, n) => { const o = []; for (const x of list) { if (o.length >= n) break; if (shownQ.has(x.slug)) continue; shownQ.add(x.slug); o.push(x); } return o; };
      // オンボ5軸を反映：kanshin(Q5)×2 / phase(Q1)×1 / kids(Q3)×1 / route(Q2:復縁⇔離婚) / trouble(Q4:危険・揉め→相談)
      const routeFit = (m) => (!m.route || st.route === 'mitei') ? 0 : (m.route === st.route ? 1.5 : -2.5);
      const troubleFit = (m) => ((st.trouble === 'danger' || st.trouble === 'dispute') && (m.kanshin || []).includes('相談')) ? 1.5 : 0;
      const scoreA = (a) => { let s = 0; (st.kanshin || []).forEach((k) => { if ((a.kanshin || []).includes(k)) s += 2; }); if ((a.phases || []).includes(st.phase)) s += 1; if (a.kids && st.kids === 'minor') s += 1; s += routeFit(a); s += troubleFit(a); if (a.pick) s += 0.4; if (a.pri) s += a.pri; if (visited.has(a.slug)) s -= 5; return s; };
      const scoreQ = (x) => { let s = 0; (st.kanshin || []).forEach((k) => { if ((x.kanshin || []).includes(k)) s += 2; }); if ((x.phases || []).includes(st.phase)) s += 1; s += routeFit(x); s += troubleFit(x); return s; };
      const recA = takeA([...A].sort((a, b) => scoreA(b) - scoreA(a)).filter((a) => scoreA(a) > 0), 4);
      const recQ = takeQ([...Q].sort((a, b) => scoreQ(b) - scoreQ(a)).filter((x) => scoreQ(x) > 0), 4);
      const rank = takeA([...A].sort((a, b) => (a.rank || 99) - (b.rank || 99)), 3);
      const toku = takeA(A.filter((a) => a.pick), 2);
      const arr = takeA([...A].sort((a, b) => (a.published < b.published ? 1 : -1)), 3);
      railsEl.innerHTML =
        railA('お前におすすめの記事', '現在地に合わせて', recA) +
        railQ('お前におすすめのQ&A', '同じ道を通った男たちの、よくある疑問', recQ.length ? recQ : takeQ(Q, 3)) +
        railRank('よく読まれている記事', rank) +
        railA('特集・編集部ピック', '', toku) +
        railA('新着', '', arr);
    }

    function renderEmpty() {
      const railsEl = document.getElementById('rails');
      const shownA = new Set();
      const takeA = (list, n) => { const o = []; for (const a of list) { if (o.length >= n) break; if (shownA.has(a.slug)) continue; shownA.add(a.slug); o.push(a); } return o; };
      const popA = takeA([...A].sort((a, b) => (a.rank || 99) - (b.rank || 99)), 4);
      const toku = takeA(A.filter((a) => a.pick), 2);
      const arr = takeA([...A].sort((a, b) => (a.published < b.published ? 1 : -1)), 3);
      const popQ = Q.slice(0, 4);
      railsEl.innerHTML =
        railA('よく読まれている記事', '', popA) +
        railQ('よく読まれているQ&A', '同じ道を通った男たちの、よくある疑問', popQ) +
        railA('特集・編集部ピック', '', toku) +
        railA('新着', '', arr);
    }

    const st = read();
    if (st && (st.phase || (st.kanshin && st.kanshin.length) || st.route)) renderMypage(st);
    else renderEmpty();
  </script>
</BaseLayout>
