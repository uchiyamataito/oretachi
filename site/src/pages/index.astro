---
// トップ＝回遊ハブ／マイページ（15§8-3レール＋§0.9現在地マップ=時系列）。
// 改修：本物の縦タイムライン／TODAY・アバター削除／全レール横断で重複表示なし／新着は少数。
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles');

const META = {
  'rikon-kiridasareta-saisho-14nichi': { phases: ['切り出された直後'], kanshin: ['初動', '気持ち'], seq: 1, pick: true, rank: 2, tag: '気持ち・初動' },
  'rikon-nani-kara-hajimeru':          { phases: ['切り出された直後'], kanshin: ['全体', '手続き'], seq: 2, pick: true, rank: 3, tag: '全体マップ' },
  'rikon-okane-checklist':             { phases: ['切り出された直後', '別居'], kanshin: ['お金'], seq: 3, rank: 1, tag: 'お金' },
  'rikon-dansei-soudansaki':           { phases: ['切り出された直後', '別居', '協議・調停中', '成立後', 'まだ別れたくない'], kanshin: ['相談', '気持ち'], seq: 2, pick: true, rank: 4, tag: '相談' },
  'rikon-mada-wakaretakunai':          { phases: ['まだ別れたくない'], kanshin: ['気持ち'], seq: 1, rank: 5, tag: '気持ち' },
  'rikon-kenkohoken-tetsuzuki':        { phases: ['別居', '成立後'], kanshin: ['手続き', 'お金'], seq: 4, rank: 6, tag: '手続き' },
  'rikon-kodomo-hoken':                { phases: ['別居', '成立後'], kanshin: ['子ども', '手続き'], seq: 5, tag: '子ども' },
  'rikon-nenkin-tetsuzuki':            { phases: ['成立後'], kanshin: ['手続き', 'お金'], seq: 6, tag: '手続き' },
  'rikon-fuyou-zeikin':                { phases: ['成立後'], kanshin: ['お金', '手続き'], seq: 7, tag: 'お金' },
  'rikon-seimeihoken-sonomama':        { phases: ['成立後'], kanshin: ['お金', '手続き'], seq: 8, tag: 'お金' },
  'rikon-seimeihoken-uketorinin':      { phases: ['成立後'], kanshin: ['お金', '手続き'], seq: 9, tag: '手続き' },
};
const data = all.map((a) => ({
  slug: a.slug, title: a.data.title, img: a.data.hero_image?.src || '', published: a.data.published,
  ...(META[a.slug] || { phases: [], kanshin: [], seq: 99, pick: false, rank: 99, tag: '記事' }),
}));
const onb = [
  { label: '切り出された直後',   hint: 'まず最初の14日にやること',       icon: 'clock-hour-4',   href: '/rikon-kiridasareta-saisho-14nichi', phase: '切り出された直後', kanshin: '初動' },
  { label: 'お金が不安',         hint: '財産分与・棚卸し・これからのお金', icon: 'coin',          href: '/rikon-okane-checklist',            phase: '', kanshin: 'お金' },
  { label: '子どものこと',       hint: '保険証・児童手当・親権の前提',   icon: 'mood-kid',      href: '/rikon-kodomo-hoken',               phase: '', kanshin: '子ども' },
  { label: 'まだ別れたくない',   hint: '追いすがる前に読んでほしい',     icon: 'heart',         href: '/rikon-mada-wakaretakunai',         phase: 'まだ別れたくない', kanshin: '気持ち' },
  { label: '誰にも言えない',     hint: '一人で抱える前に・相談先',       icon: 'message-circle', href: '/rikon-dansei-soudansaki',          phase: '', kanshin: '相談' },
  { label: '何からか分からない', hint: '気持ち・お金・手続きの全体マップ', icon: 'map-2',        href: '/rikon-nani-kara-hajimeru',         phase: '', kanshin: '全体' },
];
const newest = [...all].sort((a, b) => (a.data.published < b.data.published ? 1 : -1));
---
<BaseLayout
  title="オレタチ｜離婚を切り出された男のための初動ナビ"
  description="離婚を切り出された男性のためのマイページ型ナビ。今いちばんしんどいことを選べば、あなたの現在地（時系列）に合わせて次に読むべきこと・おすすめを出します。お金・手続き・気持ち・子ども・相談先。"
  canonical="https://oretachi.me/"
>
  <div class="home">
    <div id="greet-slot"></div>
    <div id="journey-slot"></div>

    <!-- 未オンボ＝共感ヒーロー＋オンボ -->
    <div id="hero-onb">
      <section class="hero2">
        <p class="eyebrow">離婚を切り出された男のための、初動ナビ</p>
        <h1>大丈夫だ。<br>まず、一緒に整理しよう。</h1>
        <p class="sub">何から考えればいいか分からなくて、当然だ。<strong>今いちばんしんどいことを、ひとつだけ</strong>選んでくれ。あなたの「現在地」に合わせて、次に読むものを出していく。</p>
      </section>
      <div class="onb-head">今、いちばんしんどいのは？</div>
      <p class="onb-note">ひとつ選ぶだけでいい。うまく言葉にできなくて大丈夫。</p>
      <nav class="onb" aria-label="今の状況から始める">
        {onb.map((o) => (
          <a class="onb-tile" href={o.href} data-phase={o.phase} data-kanshin={o.kanshin} data-label={o.label}>
            <i class={`ti ti-${o.icon}`} aria-hidden="true"></i>
            <span class="ol">{o.label}</span>
            <span class="oh">{o.hint}</span>
          </a>
        ))}
      </nav>
      <a class="onb-talk" href="/rikon-nani-kara-hajimeru" data-kanshin="全体" data-label="何から始める">
        <i class="ti ti-messages" aria-hidden="true"></i>うまく言葉にできない時は、ここから<span class="badge">準備中</span>
      </a>
    </div>

    <!-- レール（JS生成・全レール横断で重複なし）。server fallbackはクロール用の全記事リスト -->
    <div id="rails">
      <div class="sh"><h2>記事</h2><a href="/articles">すべて見る →</a></div>
      <div class="cards">
        {newest.map((a) => (
          <a class="card" href={`/${a.slug}`}>
            <div class="thumb"><img src={a.data.hero_image?.src} alt={a.data.title} loading="lazy" /></div>
            <div class="cbody"><span class="tag1">{(META[a.slug] || {}).tag || '記事'}</span><h3>{a.data.title}</h3></div>
          </a>
        ))}
      </div>
    </div>

    <div class="nav-cards">
      <a class="nav-card" href="/articles"><i class="ti ti-news" aria-hidden="true"></i><span class="nc-body"><span class="nc-t">記事を読む</span><span class="nc-d">お金・手続き・気持ち・子ども</span></span><i class="ti ti-chevron-right nc-go" aria-hidden="true"></i></a>
      <a class="nav-card" href="/qa"><i class="ti ti-help-circle" aria-hidden="true"></i><span class="nc-body"><span class="nc-t">Q&amp;Aを見る</span><span class="nc-d">よくある疑問に、一問即答</span></span><i class="ti ti-chevron-right nc-go" aria-hidden="true"></i></a>
      <a class="nav-card" href="/rikon-dansei-soudansaki"><i class="ti ti-lifebuoy" aria-hidden="true"></i><span class="nc-body"><span class="nc-t">相談先・窓口</span><span class="nc-d">一人で抱える前に</span></span><i class="ti ti-chevron-right nc-go" aria-hidden="true"></i></a>
    </div>

    <div class="safety">
      <b>つらくて動けない時は、無理しないでくれ。</b> 眠れない・消えてしまいたいと感じるほどなら、いのちより大切なものはない。よりそいホットライン <b>0120-279-338</b>（24時間・無料）など、声を出さなくても頼れる窓口がある。詳しくは <a href="/rikon-dansei-soudansaki">相談先のページ</a>へ。
    </div>
  </div>

  <script type="application/json" id="art-data" set:html={JSON.stringify(data)}></script>
  <script>
    const KEY = 'oretachi_state';
    const read = () => { try { return JSON.parse(localStorage.getItem(KEY) || 'null'); } catch { return null; } };
    const data = JSON.parse(document.getElementById('art-data')?.textContent || '[]');
    const esc = (s) => String(s).replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]));

    document.querySelectorAll('#hero-onb .onb-tile, #hero-onb .onb-talk').forEach((el) => {
      el.addEventListener('click', () => {
        const prev = read() || {};
        const phase = el.getAttribute('data-phase') || prev.phase || '';
        const k = el.getAttribute('data-kanshin') || '';
        const kanshin = Array.from(new Set([...(prev.kanshin || []), k].filter(Boolean)));
        const hist = Array.from(new Set([...(prev.history || []), (el.getAttribute('href') || '').replace('/', '')].filter(Boolean))).slice(-12);
        localStorage.setItem(KEY, JSON.stringify({ phase, kanshin, history: hist, label: el.getAttribute('data-label') || '', ts: Date.now() }));
      });
    });

    const PHASES = [
      { key: '危機・初動', match: ['切り出された直後', ''], st: '気持ちの応急処置と、最初の14日' },
      { key: '分岐：復縁／離婚進行', match: ['まだ別れたくない', '別居', '協議・調停中'], st: '関係修復か、別居・協議・調停か' },
      { key: '再出発', match: ['成立後'], st: '生活の立て直しと、これから' },
    ];
    const phaseIndex = (p) => { for (let i = 0; i < PHASES.length; i++) if (PHASES[i].match.includes(p || '')) return i; return 0; };
    const card = (a) => `<a class="rcard" href="/${a.slug}"><div class="rthumb"><img src="${esc(a.img)}" alt="${esc(a.title)}" loading="lazy"></div><div class="rb"><span class="rtag">${esc(a.tag)}</span><div class="rt">${esc(a.title)}</div></div></a>`;
    const rail = (title, note, items) => items.length ? `<section class="rail"><div class="rail-head"><h2>${esc(title)}</h2>${note ? `<span class="rh-note">${esc(note)}</span>` : ''}</div><div class="rail-scroller">${items.map(card).join('')}</div></section>` : '';
    const rankRail = (title, items) => items.length ? `<section class="rail"><div class="rail-head"><h2>${esc(title)}</h2><span class="rh-note">いま読まれている順</span></div><div class="rank-ol">${items.map((a, i) => `<a class="rank-item ${i === 0 ? 'top' : ''}" href="/${a.slug}"><span class="rt">${esc(a.title)}</span></a>`).join('')}</div></section>` : '';

    // 重複表示なし：一度出したslugは記録し、以降のレールから除外
    const shown = new Set();
    const take = (list, n) => { const out = []; for (const a of list) { if (out.length >= n) break; if (shown.has(a.slug)) continue; shown.add(a.slug); out.push(a); } return out; };

    const st = read();
    const railsEl = document.getElementById('rails');
    const byNewest = [...data].sort((a, b) => (a.published < b.published ? 1 : -1));
    const byRank = [...data].sort((a, b) => (a.rank || 99) - (b.rank || 99));
    const bySeq = [...data].sort((a, b) => (a.seq || 99) - (b.seq || 99));

    if (st && (st.phase || (st.kanshin && st.kanshin.length))) {
      document.getElementById('hero-onb').style.display = 'none';
      const label = st.label || (st.kanshin && st.kanshin[0]) || 'あのこと';
      document.getElementById('greet-slot').innerHTML =
        `<div class="greet"><div><div class="gt">おかえり</div><div class="gs">前回は「${esc(label)}」が気がかりだったね。続きから一緒に。</div></div><button class="reset" id="reset-state">最初から</button></div>`;
      document.getElementById('reset-state')?.addEventListener('click', () => { localStorage.removeItem(KEY); location.reload(); });

      // 現在地マップ＝縦タイムライン（時系列）
      const ci = phaseIndex(st.phase);
      const nodes = PHASES.map((p, i) => {
        const cls = i < ci ? 'done' : (i === ci ? 'current' : 'future');
        const now = i === ci ? '<span class="tl-now">今ここ</span>' : '';
        return `<li class="tl-node ${cls}"><span class="tl-dot"></span><div class="tl-c"><span class="tl-ph">フェーズ${i + 1}</span><div class="tl-nm">${esc(p.key)}${now}</div><div class="tl-st">${esc(p.st)}</div></div></li>`;
      }).join('');

      // スコアで次の一歩＆おすすめ
      const score = (a) => { let s = 0; const ks = a.kanshin || []; (st.kanshin || []).forEach((k) => { if (ks.includes(k)) s += 2; }); if (st.phase && (a.phases || []).includes(st.phase)) s += 1; if (a.pick) s += 0.4; if ((st.history || []).includes(a.slug)) s -= 5; return s; };
      const ranked = [...data].sort((a, b) => score(b) - score(a));
      const next = take(ranked, 1)[0];
      const nextHtml = next ? `<a class="next-step" href="/${next.slug}"><span class="ns-k">次の一歩</span><span class="ns-b"><span class="ns-t">${esc(next.title)}</span></span><i class="ti ti-arrow-right ns-go"></i></a>` : '';
      document.getElementById('journey-slot').innerHTML = `<div class="journey"><div class="jk"><i class="ti ti-route"></i>あなたの現在地</div><ol class="tl">${nodes}</ol>${nextHtml}</div>`;

      const osusume = take(ranked.filter((a) => score(a) > 0), 4);
      const ranking = take(byRank, 3);
      const cohort = take(data.filter((a) => st.phase && (a.phases || []).includes(st.phase)), 3);
      const tokushu = take(data.filter((a) => a.pick), 2);
      const arrivals = take(byNewest, 3);
      railsEl.innerHTML =
        rail('あなたへのおすすめ', '現在地に合わせて', osusume) +
        rankRail('よく読まれている', ranking) +
        (cohort.length ? rail('同じ状況の人がよく読む', '', cohort) : '') +
        rail('特集・編集部ピック', '', tokushu) +
        rail('新着', '', arrivals);
    } else {
      const mazu = take(bySeq, 4);
      const ranking = take(byRank, 3);
      const tokushu = take(data.filter((a) => a.pick), 2);
      const arrivals = take(byNewest, 3);
      railsEl.innerHTML =
        rail('まず読むなら', '初動でつまずかないために', mazu) +
        rankRail('よく読まれている', ranking) +
        rail('特集・編集部ピック', '', tokushu) +
        rail('新着', '', arrivals);
    }
  </script>
</BaseLayout>
