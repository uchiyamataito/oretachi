---
// トップページ（F1.5デザイン）。メルカリ型カルーセル＋状況チップ＋TODAY＋記事カード＋CTA。
// データ連動：画像・タイトル・URLは記事コレクションから取得。カルーセルの並び/タグはfeaturedで curate。
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const all = await getCollection('articles');
const bySlug = Object.fromEntries(all.map((a) => [a.slug, a]));

// --- カルーセル（curate：slug＋タグ表示）。画像/タイトル/URLは記事から自動 ---
const featured = [
  { slug: 'rikon-kiridasareta-saisho-14nichi', tag: '特集・初動', sub: '14日でやること', tone: 'coral' },
  { slug: 'rikon-nani-kara-hajimeru',          tag: '手続き',     sub: '全体像',       tone: 'navy'  },
  { slug: 'rikon-okane-checklist',             tag: 'お金と手続き', sub: '財産分与',     tone: 'mint'  },
  { slug: 'rikon-dansei-soudansaki',           tag: '気持ち・相談', sub: '相談先',       tone: 'coral' },
  { slug: 'rikon-mada-wakaretakunai',          tag: '気持ち',     sub: '関係修復',     tone: 'navy'  },
].filter((f) => bySlug[f.slug]);

// --- 状況チップ（今は該当記事へ。AI層実装後に対話ナビ・モーダル起動へ差し替え） ---
const situ = [
  { label: '切り出された直後', href: '/rikon-kiridasareta-saisho-14nichi' },
  { label: 'まだ別れたくない', href: '/rikon-mada-wakaretakunai' },
  { label: 'お金が不安',       href: '/rikon-okane-checklist' },
  { label: '誰にも言えない',   href: '/rikon-dansei-soudansaki' },
];

// --- 記事カード（全記事を新着順。カテゴリからタグ色を推定） ---
const cards = [...all].sort((a, b) => (a.data.published < b.data.published ? 1 : -1));
function toneFor(cat = '') {
  if (/保険|お金|手続き|税|年金/.test(cat)) return { cls: 'tag-mint', label: 'お金と手続き' };
  if (/気持ち|初動|相談|心/.test(cat)) return { cls: 'tag-coral-s', label: '気持ち・相談' };
  return { cls: 'tag-navy', label: cat || '記事' };
}
const ovCls = { coral: 'ov-coral', mint: 'ov-mint', navy: 'ov-navy' };
const pillCls = { coral: 't-coral', mint: 't-mint', navy: 't-navy' };
---
<BaseLayout
  title="オレタチ｜離婚を切り出された男のための初動ナビ"
  description="離婚を切り出された男性へ。最初の14日にやること・やってはいけないこと・お金と手続きを男性目線で。"
  canonical="https://oretachi.me/"
>
  <h1 class="sr-only" style="position:absolute;left:-9999px">オレタチ｜離婚を切り出された男のための初動ナビ</h1>
  <div class="home">

    <!-- HERO カルーセル -->
    <section class="hero" aria-label="特集記事">
      <div class="hero-photos">
        {featured.map((f, i) => {
          const a = bySlug[f.slug];
          return (
            <a class={`photo${i === 0 ? ' is-active' : ''}`} href={`/${f.slug}`} aria-hidden={i === 0 ? 'false' : 'true'}>
              <img src={a.data.hero_image?.src} alt={a.data.title} loading={i === 0 ? 'eager' : 'lazy'} />
              <span class="ov-tags"><span class={`ov ${ovCls[f.tone]}`}>{f.tag}</span><span class="ov ov-sub">{f.sub}</span></span>
            </a>
          );
        })}
      </div>

      <div class="hero-bodies">
        {featured.map((f, i) => {
          const a = bySlug[f.slug];
          return (
            <div class={`slide${i === 0 ? ' is-active' : ''}`}>
              <a class="s-title" href={`/${f.slug}`}>{a.data.title}</a>
              <div class="pc-tags"><span class={`pill ${pillCls[f.tone]}`}>{f.tag}</span><span class="pill t-sub">{f.sub}</span></div>
            </div>
          );
        })}
        <div class="hero-dots">
          {featured.map((f, i) => (
            <button class={`dot${i === 0 ? ' is-active' : ''}`} aria-label={`特集 ${i + 1} を表示`}></button>
          ))}
          <button class="carousel-ctrl" id="carousel-toggle" aria-label="自動切替を一時停止"><i class="ti ti-player-pause"></i></button>
        </div>
      </div>
    </section>

    <!-- 今のあなたは？ -->
    <div class="lead">今のあなたは？</div>
    <nav class="situ-chips" aria-label="状況から探す">
      {situ.map((s) => (
        <a class="situ" href={s.href}><i class="ti ti-point"></i>{s.label}</a>
      ))}
    </nav>

    <!-- TODAY -->
    <div class="today">
      <div class="k"><i class="ti ti-sun-low"></i>TODAY ― 今日の、たった一つ</div>
      <div class="t">返事を急がない。「少し考えたい」で十分だ。</div>
    </div>

    <!-- 記事一覧 -->
    <div class="sh">
      <h2>記事</h2>
    </div>
    <div class="cards">
      {cards.map((a) => {
        const t = toneFor(a.data.category);
        return (
          <a class="card" href={`/${a.slug}`}>
            <div class="thumb"><img src={a.data.hero_image?.src} alt={a.data.title} loading="lazy" /></div>
            <div class="cbody"><span class={`tag-s ${t.cls}`}>{t.label}</span><h3>{a.data.title}</h3></div>
          </a>
        );
      })}
    </div>

    <!-- CTA（初動ナビ＝準備中。AI層実装後に対話ナビへ） -->
    <div class="home-cta">
      <div class="sub">あなたの状況に合わせた、最初の一歩を。</div>
      <a class="btn" href="/shindan">初動ナビを試す<i class="ti ti-arrow-right"></i></a>
    </div>

  </div>

  <script>
    // カルーセル（自動7秒・ホバー停止・手動切替・一時停止ボタン・reduced-motion尊重）
    const photos = Array.from(document.querySelectorAll('.home .photo'));
    const slides = Array.from(document.querySelectorAll('.home .hero-bodies .slide'));
    const dots = Array.from(document.querySelectorAll('.home .dot'));
    const toggle = document.getElementById('carousel-toggle');
    if (photos.length > 1) {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      let i = 0, timer = null, paused = reduce;
      const go = (n) => {
        photos[i].classList.remove('is-active'); slides[i].classList.remove('is-active'); dots[i].classList.remove('is-active');
        i = (n + photos.length) % photos.length;
        photos[i].classList.add('is-active'); slides[i].classList.add('is-active'); dots[i].classList.add('is-active');
      };
      const start = () => { if (paused) return; stop(); timer = setInterval(() => go(i + 1), 7000); };
      const stop = () => { if (timer) { clearInterval(timer); timer = null; } };
      dots.forEach((d, n) => d.addEventListener('click', () => { go(n); start(); }));
      const hero = document.querySelector('.home .hero');
      hero.addEventListener('mouseenter', stop);
      hero.addEventListener('mouseleave', start);
      if (toggle) {
        const sync = () => { toggle.innerHTML = paused ? '<i class="ti ti-player-play"></i>' : '<i class="ti ti-player-pause"></i>'; toggle.setAttribute('aria-label', paused ? '自動切替を再生' : '自動切替を一時停止'); };
        toggle.addEventListener('click', () => { paused = !paused; paused ? stop() : start(); sync(); });
        sync();
      }
      start();
    }
  </script>
</BaseLayout>
